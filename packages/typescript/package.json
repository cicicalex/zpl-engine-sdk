{
  "name": "@zeropointlogic/sdk",
  "version": "2.0.5",
  "description": "Official TypeScript SDK for the ZPL Engine API - AI Neutrality Index calculations for crypto, forex, commodities, and game economy analysis",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "type-check": "tsc --noEmit",
    "test": "npm run build && node --test test/*.mjs",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "prepublish": "npm run build"
  },
  "keywords": [
    "zpl",
    "zero-point-logic",
    "stability",
    "bias",
    "neutrality",
    "ain",
    "fintech",
    "crypto",
    "forex",
    "commodities",
    "game-dev",
    "analysis",
    "sdk"
  ],
  "author": "Zero Point Logic <info@zeropointlogic.io>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cicicalex/zpl-engine-sdk.git",
    "directory": "packages/typescript"
  },
  "bugs": {
    "url": "https://github.com/cicicalex/zpl-engine-sdk/issues"
  },
  "homepage": "https://github.com/cicicalex/zpl-engine-sdk#readme",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "prettier": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
